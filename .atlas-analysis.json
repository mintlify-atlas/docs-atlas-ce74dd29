  "keyFeatures": [
    "Token-based authentication with automatic expiry management",
    "Biometric login (fingerprint) via local_auth",
    "Secure door unlock with configurable timed access",
    "Favorites tab for quick access to preferred doors",
    "Search and filter functionality for door lists",
    "Animated splash screen with fingerprint scan sequence",
    "Material 3 theming with light/dark mode and custom color picker",
    "Over-the-air (OTA) updates via GitHub Releases",
    "Responsive layout supporting both mobile and wide-screen with NavigationRail"
  ],
  "publicApiSurface": [
    "AuthService.login(email, password) -> AuthData",
    "AuthService.loadStoredAuth() -> AuthData?",
    "AuthService.clearAuth()",
    "DoorService.fetchDoors(tenantId, token) -> Building",
    "DoorService.unlockDoor(doorId, tenantId, token, minutes)",
    "UpdateService.checkForUpdates(context, showNoUpdateDialog)",
    "AuthProvider (ChangeNotifier): login, logout, biometricLogin, loadAuthState",
    "ThemeProvider (ChangeNotifier): toggleTheme, updateSeedColor",
    "FavoritesProvider (ChangeNotifier): add/remove/toggle favorites",
    "Building, Floor, Door data models",
    "DoorType enum: suite, washroomMen, washroomWomen, staircase, conference, genericFloorDoor, other"
  ]
